#
# Copy this file to .env and fill real values.
# Never commit .env with real secrets.
#

### Common / Profiles
SPRING_PROFILES_ACTIVE=dev

### Public app URL (used for LiqPay result_url/server_url callbacks)
# Dev: http://localhost:8081 or your ngrok HTTPS URL
# Prod: https://smart-dine.westeurope.cloudapp.azure.com
APP_PUBLIC_BASE_URL=http://localhost:8081

### Hostname for Production (Azure VM DNS)
# DOMAIN=smart-dine.westeurope.cloudapp.azure.com

### CORS + WebSocket origins (comma-separated)
# Dev:
APP_ALLOWED_ORIGINS=http://localhost:8081,http://localhost:8080
# Prod example:
# APP_ALLOWED_ORIGINS=https://smart-dine.westeurope.cloudapp.azure.com

### Database (Postgres)
POSTGRES_PASSWORD=change_me

# Optional: override datasource explicitly (useful outside docker, or for prod compose clarity)
# SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/restaurant_db
# SPRING_DATASOURCE_USERNAME=postgres
# SPRING_DATASOURCE_PASSWORD=change_me

# Schema strategy: usually validate in prod; for first deploy on empty DB you may temporarily set update
SPRING_JPA_HIBERNATE_DDL_AUTO=validate

### Keycloak (OAuth2)
# Public URL for browser redirects (e.g., https://domain.com/auth)
KEYCLOAK_AUTH_SERVER_URL=http://localhost:8080

# Browser-facing URL (login redirects)
KEYCLOAK_PUBLIC_URL=http://localhost:8080

# Server-to-server URL (used from the app container inside docker network)
KEYCLOAK_INTERNAL_URL=http://keycloak:8080

# Public hostname for Keycloak (without protocol/path, e.g., domain.com)
KEYCLOAK_HOSTNAME=localhost

# Client credentials
KEYCLOAK_CLIENT_SECRET=change_me

# Keycloak Admin bootstrap
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=change_me

# Database for Keycloak (used in docker-compose.keycloak.yml)
KEYCLOAK_DB_PASSWORD=change_me

### LiqPay
LIQPAY_PUBLIC_KEY=change_me
LIQPAY_PRIVATE_KEY=change_me

### Web Push (VAPID)
VAPID_PUBLIC_KEY=change_me
VAPID_PRIVATE_KEY=change_me
VAPID_SUBJECT=mailto:admin@example.com